@prefix as: <https://agentstreams.dev/ontology#> .
@prefix map: <https://agentstreams.dev/mapping#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .

# ═══════════════════════════════════════════════════════════
# UDA Mappings — Ontology → Neon Postgres (pg_graphql)
# Maps each ontology class/property to its physical table/column
# ═══════════════════════════════════════════════════════════

map:Mapping a rdfs:Class ;
    rdfs:label "Mapping" ;
    rdfs:comment "Links an ontology concept to a physical storage location." .

map:ontologyClass a rdf:Property ;
    rdfs:domain map:Mapping ;
    rdfs:range rdfs:Class .

map:targetTable a rdf:Property ;
    rdfs:domain map:Mapping ;
    rdfs:range xsd:string .

map:ontologyProperty a rdf:Property ;
    rdfs:domain map:Mapping ;
    rdfs:range rdf:Property .

map:targetColumn a rdf:Property ;
    rdfs:domain map:Mapping ;
    rdfs:range xsd:string .

# ── Skill mappings ────────────────────────────────────────

map:skill-table a map:Mapping ;
    map:ontologyClass as:Skill ;
    map:targetTable "skills" ;
    rdfs:label "Skill → skills table" .

map:skill-name a map:Mapping ;
    map:ontologyProperty as:skillName ;
    map:targetTable "skills" ;
    map:targetColumn "name" .

map:skill-description a map:Mapping ;
    map:ontologyProperty as:description ;
    map:targetTable "skills" ;
    map:targetColumn "description" .

map:skill-trigger a map:Mapping ;
    map:ontologyProperty as:triggerPattern ;
    map:targetTable "skills" ;
    map:targetColumn "trigger_pattern" .

