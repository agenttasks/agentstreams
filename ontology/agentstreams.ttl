# ── Instances: UDA Architecture ──────────────────────────

# DSPy Signatures (pre-built in src/dspy_prompts.py)
as:sig-extract-entities a as:DSPySignature ;
    as:signatureName "ExtractEntities" ;
    as:signatureDoc "Extract structured entities from crawled documentation page content." ;
    rdfs:label "Extract Entities Signature" .

as:sig-classify-content a as:DSPySignature ;
    as:signatureName "ClassifyContent" ;
    as:signatureDoc "Classify crawled content into skill-relevant categories." ;
    rdfs:label "Classify Content Signature" .

as:sig-extract-api-patterns a as:DSPySignature ;
    as:signatureName "ExtractAPIPatterns" ;
    as:signatureDoc "Extract API usage patterns, code samples, and SDK constructor calls." ;
    rdfs:label "Extract API Patterns Signature" .

as:sig-align-to-ontology a as:DSPySignature ;
    as:signatureName "AlignToOntology" ;
    as:signatureDoc "Map extracted entities to AgentStreams ontology classes and properties." ;
    rdfs:label "Align to Ontology Signature" .

# Subagents (headless DSPy pipeline runners)
as:subagent-crawler a as:Subagent ;
    as:subagentName "uda-crawler" ;
    rdfs:label "UDA Crawler Subagent" ;
    rdfs:comment "Web crawling with bloom filter dedup and Neon persistence." .

as:subagent-extractor a as:Subagent ;
    as:subagentName "uda-extractor" ;
    as:subagentPipeline "ExtractEntities → ClassifyContent → AlignToOntology" ;
    rdfs:label "UDA Extractor Subagent" ;
    rdfs:comment "DSPy structured extraction with ontology alignment." .

as:subagent-projector a as:Subagent ;
    as:subagentName "uda-projector" ;
    rdfs:label "UDA Projector Subagent" ;
    rdfs:comment "Ontology projection generator: Avro, GraphQL, DataContainer, Mapping." .

# Agent Manifests for UDA agents
as:manifest-uda-crawler a as:AgentManifest ;
    as:manifestName "uda-crawler" ;
    as:allowedTool "Read", "Glob", "Grep", "Bash", "Write" ;
    rdfs:label "UDA Crawler Agent Manifest" .

as:manifest-uda-extractor a as:AgentManifest ;
    as:manifestName "uda-extractor" ;
    as:allowedTool "Read", "Glob", "Grep", "Bash" ;
    rdfs:label "UDA Extractor Agent Manifest" .

as:manifest-uda-thinker a as:AgentManifest ;
    as:manifestName "uda-thinker" ;
    as:manifestModel "opus" ;
    as:allowedTool "Read", "Glob", "Grep", "Bash" ;
    rdfs:label "UDA Thinker Agent Manifest" .

as:subagent-thinker a as:Subagent ;
    as:subagentName "uda-thinker" ;
    as:subagentPipeline "ExtendedThinking → AdaptiveThinking → record_thinking_trace" ;
    rdfs:label "UDA Thinker Subagent" ;
    rdfs:comment "Deep reasoning with extended/adaptive thinking and Neon extension integration." .
