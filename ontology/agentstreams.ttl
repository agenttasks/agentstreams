@prefix as: <https://agentstreams.dev/ontology#> .
@prefix rdf: <http://www.w3.org/1999/02/22-rdf-syntax-ns#> .
@prefix rdfs: <http://www.w3.org/2000/01/rdf-schema#> .
@prefix xsd: <http://www.w3.org/2001/XMLSchema#> .
@prefix skos: <http://www.w3.org/2004/02/skos/core#> .

# ═══════════════════════════════════════════════════════════
# AgentStreams Ontology — Model Once, Represent Everywhere
# Inspired by Netflix UDA (Unified Data Architecture)
# ═══════════════════════════════════════════════════════════

# ── UDA Core Classes ─────────────────────────────────────
# Following Netflix UDA: ontology is source of truth,
# all physical/API representations are projections.

as:DataContainer a rdfs:Class ;
    rdfs:label "Data Container" ;
    rdfs:comment "A data mesh source registration — the projected Avro/GraphQL schema for an ontology class. UDA pattern from Netflix." ;
    skos:example "Skill_source, Model_source, CrawlPage_source" .

as:OntologyMapping a rdfs:Class ;
    rdfs:label "Ontology Mapping" ;
    rdfs:comment "Links an ontology concept to a physical storage location (table/column). Bridges semantic and physical layers." .

as:Projection a rdfs:Class ;
    rdfs:label "Projection" ;
    rdfs:comment "A format-specific representation generated from the ontology: Avro, GraphQL, DataContainer TTL, or Mapping TTL." .

as:ProjectionFormat a rdfs:Class ;
    rdfs:label "Projection Format" .

as:AvroFormat a as:ProjectionFormat ; rdfs:label "Avro" .
as:GraphQLFormat a as:ProjectionFormat ; rdfs:label "GraphQL" .
as:DataContainerTTL a as:ProjectionFormat ; rdfs:label "DataContainer TTL" .
as:MappingTTL a as:ProjectionFormat ; rdfs:label "Mapping TTL" .

as:BloomFilterState a rdfs:Class ;
    rdfs:label "Bloom Filter State" ;
    rdfs:comment "Persistent bloom filter for cross-session deduplication. Stored as bit array in Neon Postgres." .

as:CrawlPage a rdfs:Class ;
    rdfs:label "Crawl Page" ;
    rdfs:comment "A web page fetched by UDACrawler with content, hash, and metadata. DataContainer in the crawl pipeline." .

as:DSPySignature a rdfs:Class ;
    rdfs:label "DSPy Signature" ;
    rdfs:comment "A typed I/O contract for DSPy modules — defines input and output fields for structured extraction." .

as:DSPyModule a rdfs:Class ;
    rdfs:label "DSPy Module" ;
    rdfs:comment "A prompt module wrapping a Signature with execution logic. Composable into Pipelines." .

as:Subagent a rdfs:Class ;
    rdfs:label "Subagent" ;
    rdfs:comment "A headless DSPy subagent that runs extraction pipelines autonomously with Neon persistence." .

as:Embedding a rdfs:Class ;
    rdfs:label "Embedding" ;
    rdfs:comment "A vector embedding of text content stored in LanceDB (local) or Neon pgvector (remote). Follows mempalace drawer pattern with wing/room taxonomy." .

as:EmbeddingBackend a rdfs:Class ;
    rdfs:label "Embedding Backend" .

as:ThinkingTrace a rdfs:Class ;
    rdfs:label "Thinking Trace" ;
    rdfs:comment "Audit record for extended-thinking or adaptive-thinking API calls. Tracks budget, actual tokens, model, and duration." .

as:ThinkingMode a rdfs:Class ;
    rdfs:label "Thinking Mode" .

as:EnabledThinking a as:ThinkingMode ;
    rdfs:label "Extended Thinking" ;
    rdfs:comment "Fixed budget deep reasoning: thinking={type: enabled, budget_tokens: N}." .

as:AdaptiveThinking a as:ThinkingMode ;
    rdfs:label "Adaptive Thinking" ;
    rdfs:comment "Self-calibrating reasoning: thinking={type: adaptive}. Claude 4.6 feature." .

as:TokenCount a rdfs:Class ;
    rdfs:label "Token Count" ;
    rdfs:comment "Token count record from pg_tiktoken extension. Tracks tokenization of crawled content, DSPy I/O, and embeddings." .

as:HLLSketch a rdfs:Class ;
    rdfs:label "HyperLogLog Sketch" ;
    rdfs:comment "Approximate distinct count sketch from hll extension. Complements bloom filters for cardinality estimation." .

as:LanceDBBackend a as:EmbeddingBackend ;
    rdfs:label "LanceDB" ;
    rdfs:comment "Local columnar vector store — millisecond queries, no server." .

as:PgVectorBackend a as:EmbeddingBackend ;
    rdfs:label "pgvector" ;
    rdfs:comment "Neon Postgres vector extension — SQL-native similarity search." .

# ── Core Classes ──────────────────────────────────────────

as:Skill a rdfs:Class ;
    rdfs:label "Skill" ;
    rdfs:comment "A multi-language capability package providing patterns, code, and configuration for a specific domain." ;
    skos:example "crawl-ingest, api-client, data-pipeline" .

as:Language a rdfs:Class ;
    rdfs:label "Language" ;
    rdfs:comment "A programming language supported by the skill system." .

as:Model a rdfs:Class ;
    rdfs:label "Model" ;
    rdfs:comment "A Claude model version with specific capabilities and pricing." .

as:SDK a rdfs:Class ;
    rdfs:label "SDK" ;
    rdfs:comment "An official Anthropic SDK for a specific language." .

as:MCPServer a rdfs:Class ;
    rdfs:label "MCP Server" ;
    rdfs:comment "A Model Context Protocol server providing tools and resources." .

as:Package a rdfs:Class ;
    rdfs:label "Package" ;
    rdfs:comment "A third-party library used within a skill for a specific language." .

as:Pipeline a rdfs:Class ;
    rdfs:label "Pipeline" ;
    rdfs:comment "A data processing pipeline instance — ETL, crawl, or API integration." .

as:Metric a rdfs:Class ;
    rdfs:label "Metric" ;
    rdfs:comment "A dimensional time-series metric (Atlas/Spectator pattern)." .

as:EvalSuite a rdfs:Class ;
    rdfs:label "Eval Suite" ;
    rdfs:comment "A collection of evaluation test cases for a skill or pipeline." .

as:Resource a rdfs:Class ;
    rdfs:label "Resource" ;
    rdfs:comment "An external documentation or reference resource (Claude platform, GitHub, etc.)." .

as:Prompt a rdfs:Class ;
    rdfs:label "Prompt" ;
    rdfs:comment "An agentic prompt pattern — system, agent, tool, or skill prompt with structured XML representation." ;
    skos:example "verification-agent, coordinator, auto-mode-classifier" .

as:PromptType a rdfs:Class ;
    rdfs:label "Prompt Type" ;
    rdfs:comment "Classification of prompt role in the agent system." .

as:SystemPrompt a as:PromptType ;
    rdfs:label "System Prompt" ;
    rdfs:comment "Core behavioral instructions defining agent identity and boundaries." .

as:AgentPrompt a as:PromptType ;
    rdfs:label "Agent Prompt" ;
    rdfs:comment "Specialized agent configuration for delegated task execution." .

as:ToolPrompt a as:PromptType ;
    rdfs:label "Tool Prompt" ;
    rdfs:comment "Guidance embedded in tool schemas for specific tool behaviors." .

as:SkillPrompt a as:PromptType ;
    rdfs:label "Skill Prompt" ;
    rdfs:comment "Reusable workflow definition invoked via slash commands." .

as:AgentManifest a rdfs:Class ;
    rdfs:label "Agent Manifest" ;
    rdfs:comment "A .claude/agents/ configuration file defining a specialized agent with tools, model, and system prompt." ;
    skos:example "coordinator, verification, explore" .

as:Task a rdfs:Class ;
    rdfs:label "Task" ;
    rdfs:comment "A queued unit of work — code task (Claude Code) or knowledge-work task (plugin). Processed via pgqueuer." .

as:TaskType a rdfs:Class ;
    rdfs:label "Task Type" ;
    rdfs:comment "Classification of task origin and processing pathway." .

as:CodeTask a as:TaskType ;
    rdfs:label "Code Task" ;
    rdfs:comment "Task executed via Claude Code CLI/SDK/API." .

as:KnowledgeWorkTask a as:TaskType ;
    rdfs:label "Knowledge Work Task" ;
    rdfs:comment "Task executed via knowledge-work-plugins (cowork)." .

as:FinancialTask a as:TaskType ;
    rdfs:label "Financial Task" ;
    rdfs:comment "Task executed via financial-services-plugins." .

# ── Enumerations ──────────────────────────────────────────

as:LanguageTier a rdfs:Class ;
    rdfs:label "Language Tier" ;
    rdfs:comment "Capability tier for a language within a skill." .

as:Tier1 a as:LanguageTier ;
    rdfs:label "Tier 1" ;
    rdfs:comment "Full stack: SDK + Agent SDK + MCP + primary framework + bloom/quality + LSP + DSPy + evals." .

as:Tier2 a as:LanguageTier ;
    rdfs:label "Tier 2" ;
    rdfs:comment "SDK + MCP + framework + bloom/quality + LSP. No Agent SDK, limited DSPy." .

as:Tier3 a as:LanguageTier ;
    rdfs:label "Tier 3" ;
    rdfs:comment "SDK + MCP + basic framework. Minimal tooling." .

as:MetricType a rdfs:Class ;
    rdfs:label "Metric Type" ;
    rdfs:comment "Type of dimensional metric (Spectator pattern)." .

as:Counter a as:MetricType ;
    rdfs:label "Counter" ;
    rdfs:comment "Monotonically increasing count. Rate is the primary query." .

as:Timer a as:MetricType ;
    rdfs:label "Timer" ;
    rdfs:comment "Duration measurement. Reports count, totalTime, max." .

as:Gauge a as:MetricType ;
    rdfs:label "Gauge" ;
    rdfs:comment "Instantaneous value snapshot." .

as:DistributionSummary a as:MetricType ;
    rdfs:label "Distribution Summary" ;
    rdfs:comment "Value distribution. Reports count, totalAmount, max." .

as:ResourceType a rdfs:Class ;
    rdfs:label "Resource Type" .

as:ModelCard a as:ResourceType ;
    rdfs:label "Model Card" .

as:APIPrimer a as:ResourceType ;
    rdfs:label "API Primer" ;
    rdfs:comment "Concise API guide optimized for LLM ingestion." .

as:LLMsIndex a as:ResourceType ;
    rdfs:label "LLMs Index" ;
    rdfs:comment "Machine-readable documentation index (llms.txt)." .

as:Cookbook a as:ResourceType ;
    rdfs:label "Cookbook" ;
    rdfs:comment "Replicable code samples and implementations." .

# ── Properties ────────────────────────────────────────────

# Skill properties
as:skillName a rdf:Property ;
    rdfs:domain as:Skill ;
    rdfs:range xsd:string ;
    rdfs:comment "Machine-readable skill identifier." .

as:description a rdf:Property ;
    rdfs:domain as:Skill ;
    rdfs:range xsd:string .

as:triggerPattern a rdf:Property ;
    rdfs:domain as:Skill ;
    rdfs:range xsd:string ;
    rdfs:comment "Natural language description of when this skill should activate." .

as:supportsLanguage a rdf:Property ;
    rdfs:domain as:Skill ;
    rdfs:range as:Language .

as:languageTier a rdf:Property ;
    rdfs:comment "The tier of a language within a specific skill." ;
    rdfs:range as:LanguageTier .

# Model properties
as:modelId a rdf:Property ;
    rdfs:domain as:Model ;
    rdfs:range xsd:string ;
    rdfs:comment "API model identifier, hyphen format (e.g. claude-opus-4-6)." .

as:modelFamily a rdf:Property ;
    rdfs:domain as:Model ;
    rdfs:range xsd:string .

as:supportsThinking a rdf:Property ;
    rdfs:domain as:Model ;
    rdfs:range xsd:boolean .

as:supportsToolUse a rdf:Property ;
    rdfs:domain as:Model ;
    rdfs:range xsd:boolean .

as:supportsVision a rdf:Property ;
    rdfs:domain as:Model ;
    rdfs:range xsd:boolean .

# SDK properties
as:sdkLanguage a rdf:Property ;
    rdfs:domain as:SDK ;
    rdfs:range as:Language .

as:sdkRepo a rdf:Property ;
    rdfs:domain as:SDK ;
    rdfs:range xsd:anyURI .

as:sdkStars a rdf:Property ;
    rdfs:domain as:SDK ;
    rdfs:range xsd:integer .

as:constructorPattern a rdf:Property ;
    rdfs:domain as:SDK ;
    rdfs:range xsd:string ;
    rdfs:comment "The correct constructor call for this SDK (e.g. 'new Anthropic()')." .

# Package properties
as:packageName a rdf:Property ;
    rdfs:domain as:Package ;
    rdfs:range xsd:string .

as:packageVersion a rdf:Property ;
    rdfs:domain as:Package ;
    rdfs:range xsd:string .

as:packageLanguage a rdf:Property ;
    rdfs:domain as:Package ;
    rdfs:range as:Language .

as:usedBySkill a rdf:Property ;
    rdfs:domain as:Package ;
    rdfs:range as:Skill .

# Metric properties (Atlas/Spectator dimensional model)
as:metricName a rdf:Property ;
    rdfs:domain as:Metric ;
    rdfs:range xsd:string .

as:metricType a rdf:Property ;
    rdfs:domain as:Metric ;
    rdfs:range as:MetricType .

as:metricUnit a rdf:Property ;
    rdfs:domain as:Metric ;
    rdfs:range xsd:string .

as:hasDimension a rdf:Property ;
    rdfs:domain as:Metric ;
    rdfs:range xsd:string ;
    rdfs:comment "A tag key for dimensional slicing (e.g. 'skill', 'language', 'model')." .

# Pipeline properties
as:pipelineSkill a rdf:Property ;
    rdfs:domain as:Pipeline ;
    rdfs:range as:Skill .

as:pipelineModel a rdf:Property ;
    rdfs:domain as:Pipeline ;
    rdfs:range as:Model .

as:emitsMetric a rdf:Property ;
    rdfs:domain as:Pipeline ;
    rdfs:range as:Metric .

# Resource properties
as:resourceType a rdf:Property ;
    rdfs:domain as:Resource ;
    rdfs:range as:ResourceType .

as:resourceURL a rdf:Property ;
    rdfs:domain as:Resource ;
    rdfs:range xsd:anyURI .

as:relatedModel a rdf:Property ;
    rdfs:domain as:Resource ;
    rdfs:range as:Model .

# Prompt properties
as:promptId a rdf:Property ;
    rdfs:domain as:Prompt ;
    rdfs:range xsd:string ;
    rdfs:comment "Two-digit zero-padded identifier (e.g. '07')." .

as:promptName a rdf:Property ;
    rdfs:domain as:Prompt ;
    rdfs:range xsd:string ;
    rdfs:comment "Kebab-case name (e.g. 'verification-agent')." .

as:promptType a rdf:Property ;
    rdfs:domain as:Prompt ;
    rdfs:range as:PromptType .

as:promptPurpose a rdf:Property ;
    rdfs:domain as:Prompt ;
    rdfs:range xsd:string .

as:promptSourceFile a rdf:Property ;
    rdfs:domain as:Prompt ;
    rdfs:range xsd:string ;
    rdfs:comment "Path to source markdown file in vendors/." .

as:promptTag a rdf:Property ;
    rdfs:domain as:Prompt ;
    rdfs:range xsd:string ;
    rdfs:comment "Classification tag (e.g. 'security', 'verification', 'parallel')." .

as:belongsToSkill a rdf:Property ;
    rdfs:domain as:Prompt ;
    rdfs:range as:Skill .

# Agent manifest properties
as:manifestName a rdf:Property ;
    rdfs:domain as:AgentManifest ;
    rdfs:range xsd:string .

as:manifestModel a rdf:Property ;
    rdfs:domain as:AgentManifest ;
    rdfs:range xsd:string ;
    rdfs:comment "Model override (e.g. 'haiku')." .

as:allowedTool a rdf:Property ;
    rdfs:domain as:AgentManifest ;
    rdfs:range xsd:string .

as:deniedTool a rdf:Property ;
    rdfs:domain as:AgentManifest ;
    rdfs:range xsd:string .

as:derivedFromPrompt a rdf:Property ;
    rdfs:domain as:AgentManifest ;
    rdfs:range as:Prompt ;
    rdfs:comment "The source prompt pattern this manifest was derived from." .

# Task properties
as:taskType a rdf:Property ;
    rdfs:domain as:Task ;
    rdfs:range as:TaskType .

as:taskSkill a rdf:Property ;
    rdfs:domain as:Task ;
    rdfs:range as:Skill ;
    rdfs:comment "The skill this task invokes." .

as:taskModel a rdf:Property ;
    rdfs:domain as:Task ;
    rdfs:range as:Model ;
    rdfs:comment "The model used to process this task." .

as:taskPlugin a rdf:Property ;
    rdfs:domain as:Task ;
    rdfs:range xsd:string ;
    rdfs:comment "Plugin identifier (e.g. 'sales-development', 'financial-analysis')." .

as:taskStatus a rdf:Property ;
    rdfs:domain as:Task ;
    rdfs:range xsd:string ;
    rdfs:comment "Task lifecycle: queued → processing → completed | failed | cancelled." .

as:taskInput a rdf:Property ;
    rdfs:domain as:Task ;
    rdfs:range xsd:string ;
    rdfs:comment "Task input payload (JSONB in physical layer)." .

as:taskOutput a rdf:Property ;
    rdfs:domain as:Task ;
    rdfs:range xsd:string ;
    rdfs:comment "Task output/result payload (JSONB in physical layer)." .

as:taskConfig a rdf:Property ;
    rdfs:domain as:Task ;
    rdfs:range xsd:string ;
    rdfs:comment "Task configuration/parameters (JSONB in physical layer)." .

# ── Properties: UDA Architecture ─────────────────────────

as:containerSource a rdf:Property ;
    rdfs:domain as:DataContainer ;
    rdfs:range xsd:string ;
    rdfs:comment "Data mesh source identifier." .

as:projectsClass a rdf:Property ;
    rdfs:domain as:DataContainer ;
    rdfs:range rdfs:Class ;
    rdfs:comment "The ontology class this container projects." .

as:projectionFormat a rdf:Property ;
    rdfs:domain as:Projection ;
    rdfs:range as:ProjectionFormat .

as:projectionSource a rdf:Property ;
    rdfs:domain as:Projection ;
    rdfs:range rdfs:Class ;
    rdfs:comment "Ontology class the projection is generated from." .

as:bloomName a rdf:Property ;
    rdfs:domain as:BloomFilterState ;
    rdfs:range xsd:string .

as:bloomDomain a rdf:Property ;
    rdfs:domain as:BloomFilterState ;
    rdfs:range xsd:string .

as:bloomExpectedItems a rdf:Property ;
    rdfs:domain as:BloomFilterState ;
    rdfs:range xsd:integer .

as:bloomFpRate a rdf:Property ;
    rdfs:domain as:BloomFilterState ;
    rdfs:range xsd:float .

as:crawlURL a rdf:Property ;
    rdfs:domain as:CrawlPage ;
    rdfs:range xsd:anyURI .

as:crawlDomain a rdf:Property ;
    rdfs:domain as:CrawlPage ;
    rdfs:range xsd:string .

as:crawlContentHash a rdf:Property ;
    rdfs:domain as:CrawlPage ;
    rdfs:range xsd:string .

as:crawlTitle a rdf:Property ;
    rdfs:domain as:CrawlPage ;
    rdfs:range xsd:string .

as:signatureName a rdf:Property ;
    rdfs:domain as:DSPySignature ;
    rdfs:range xsd:string .

as:signatureDoc a rdf:Property ;
    rdfs:domain as:DSPySignature ;
    rdfs:range xsd:string .

as:moduleSigRef a rdf:Property ;
    rdfs:domain as:DSPyModule ;
    rdfs:range as:DSPySignature .

as:moduleModel a rdf:Property ;
    rdfs:domain as:DSPyModule ;
    rdfs:range as:Model .

as:subagentName a rdf:Property ;
    rdfs:domain as:Subagent ;
    rdfs:range xsd:string .

as:subagentPipeline a rdf:Property ;
    rdfs:domain as:Subagent ;
    rdfs:range xsd:string ;
    rdfs:comment "Ordered list of DSPy module names in the pipeline." .

as:embeddingWing a rdf:Property ;
    rdfs:domain as:Embedding ;
    rdfs:range xsd:string ;
    rdfs:comment "Mempalace wing (domain): ontology, skills, docs, code." .

as:embeddingRoom a rdf:Property ;
    rdfs:domain as:Embedding ;
    rdfs:range xsd:string ;
    rdfs:comment "Mempalace room (topic): tool-use, streaming, agents, mcp." .

as:embeddingBackend a rdf:Property ;
    rdfs:domain as:Embedding ;
    rdfs:range as:EmbeddingBackend .

as:embeddingDim a rdf:Property ;
    rdfs:domain as:Embedding ;
    rdfs:range xsd:integer ;
    rdfs:comment "Embedding vector dimension (default 384)." .

# Properties: Thinking traces
as:thinkingMode a rdf:Property ;
    rdfs:domain as:ThinkingTrace ;
    rdfs:range as:ThinkingMode .

as:thinkingBudget a rdf:Property ;
    rdfs:domain as:ThinkingTrace ;
    rdfs:range xsd:integer ;
    rdfs:comment "Requested thinking token budget." .

as:thinkingTokens a rdf:Property ;
    rdfs:domain as:ThinkingTrace ;
    rdfs:range xsd:integer ;
    rdfs:comment "Actual thinking tokens consumed." .

# Properties: Token counts
as:tokenModel a rdf:Property ;
    rdfs:domain as:TokenCount ;
    rdfs:range xsd:string ;
    rdfs:comment "Tiktoken encoding: cl100k_base, p50k_base, r50k_base." .

as:tokenCount a rdf:Property ;
    rdfs:domain as:TokenCount ;
    rdfs:range xsd:integer .

# Properties: HLL sketches
as:hllName a rdf:Property ;
    rdfs:domain as:HLLSketch ;
    rdfs:range xsd:string .

as:hllCardinality a rdf:Property ;
    rdfs:domain as:HLLSketch ;
    rdfs:range xsd:integer ;
    rdfs:comment "Approximate distinct count from the sketch." .

# ── Instances: Languages ──────────────────────────────────

as:TypeScript a as:Language ; rdfs:label "TypeScript" .
as:Python a as:Language ; rdfs:label "Python" .
as:Java a as:Language ; rdfs:label "Java" .
as:Go a as:Language ; rdfs:label "Go" .
as:Ruby a as:Language ; rdfs:label "Ruby" .
as:CSharp a as:Language ; rdfs:label "C#" .
as:PHP a as:Language ; rdfs:label "PHP" .
as:Shell a as:Language ; rdfs:label "Shell/cURL" .

# ── Instances: Models ─────────────────────────────────────

as:claude-opus-4-6 a as:Model ;
    as:modelId "claude-opus-4-6" ;
    as:modelFamily "Claude 4.6" ;
    as:supportsThinking true ;
    as:supportsToolUse true ;
    as:supportsVision true ;
    rdfs:label "Claude Opus 4.6" .

as:claude-sonnet-4-6 a as:Model ;
    as:modelId "claude-sonnet-4-6" ;
    as:modelFamily "Claude 4.6" ;
    as:supportsThinking true ;
    as:supportsToolUse true ;
    as:supportsVision true ;
    rdfs:label "Claude Sonnet 4.6" .

as:claude-haiku-4-5 a as:Model ;
    as:modelId "claude-haiku-4-5-20251001" ;
    as:modelFamily "Claude 4.5" ;
    as:supportsThinking false ;
    as:supportsToolUse true ;
    as:supportsVision true ;
    rdfs:label "Claude Haiku 4.5" .

# ── Instances: SDKs ───────────────────────────────────────

as:sdk-typescript a as:SDK ;
    as:sdkLanguage as:TypeScript ;
    as:sdkStars 1800 ;
    as:constructorPattern "new Anthropic()" ;
    rdfs:label "anthropic-sdk-typescript" .

as:sdk-python a as:SDK ;
    as:sdkLanguage as:Python ;
    as:sdkStars 3100 ;
    as:constructorPattern "anthropic.Anthropic()" ;
    rdfs:label "anthropic-sdk-python" .

as:sdk-java a as:SDK ;
    as:sdkLanguage as:Java ;
    as:sdkStars 271 ;
    as:constructorPattern "AnthropicClient.builder().build()" ;
    rdfs:label "anthropic-sdk-java" .

as:sdk-go a as:SDK ;
    as:sdkLanguage as:Go ;
    as:sdkStars 943 ;
    as:constructorPattern "anthropic.NewClient()" ;
    rdfs:label "anthropic-sdk-go" .

as:sdk-ruby a as:SDK ;
    as:sdkLanguage as:Ruby ;
    as:sdkStars 312 ;
    as:constructorPattern "Anthropic::Client.new" ;
    rdfs:label "anthropic-sdk-ruby" .

as:sdk-csharp a as:SDK ;
    as:sdkLanguage as:CSharp ;
    as:sdkStars 212 ;
    as:constructorPattern "new AnthropicClient()" ;
    rdfs:label "anthropic-sdk-csharp" .

as:sdk-php a as:SDK ;
    as:sdkLanguage as:PHP ;
    as:sdkStars 128 ;
    as:constructorPattern "Anthropic::client()" ;
    rdfs:label "anthropic-sdk-php" .

# ── Instances: Skills ─────────────────────────────────────

as:crawl-ingest a as:Skill ;
    as:skillName "crawl-ingest" ;
    as:description "Web crawling, deduplication, and data ingestion using Anthropic SDKs" ;
    as:triggerPattern "crawl websites, build scrapers, deduplicate URLs, bloom filters, ingest data" ;
    as:supportsLanguage as:TypeScript, as:Python, as:Java, as:Go, as:Ruby, as:CSharp, as:PHP, as:Shell ;
    rdfs:label "Crawl-Ingest" .

as:api-client a as:Skill ;
    as:skillName "api-client" ;
    as:description "API client generation, testing, and integration using Anthropic SDKs" ;
    as:triggerPattern "build API clients, generate SDKs, test REST/GraphQL APIs, OAuth, retry/backoff" ;
    as:supportsLanguage as:TypeScript, as:Python, as:Java, as:Go, as:Ruby, as:CSharp, as:PHP, as:Shell ;
    rdfs:label "API Client" .

as:data-pipeline a as:Skill ;
    as:skillName "data-pipeline" ;
    as:description "Data pipeline orchestration, ETL/ELT, streaming, and batch processing" ;
    as:triggerPattern "build data pipelines, ETL/ELT workflows, stream processing, batch jobs, CDC" ;
    as:supportsLanguage as:TypeScript, as:Python, as:Java, as:Go, as:Ruby, as:CSharp, as:PHP, as:Shell ;
    rdfs:label "Data Pipeline" .

as:video-generation a as:Skill ;
    as:skillName "video-generation" ;
    as:description "Video generation with Google Veo models via the Gemini Cloud API" ;
    as:triggerPattern "generate video, Veo, Gemini video, YouTube content, TikTok content, video pipeline" ;
    as:supportsLanguage as:Python, as:Shell ;
    rdfs:label "Video Generation" .

