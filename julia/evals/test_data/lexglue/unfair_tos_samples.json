    "metadata": {},
    "labels": [],
    "label": null,
    "content_hash": "13f17b07a5ee84a5546b7495a1f24138"
  },
  {
    "task": "unfair_tos",
    "hf_index": 36,
    "text": "when you purchase a subscription or make any other paid feature related purchase via the services ( each , a `` transaction '' ) , you expressly authorize us ( or our third party payment processor , e.g. stripe ) to charge you for such transaction . \n",
    "label_set": [
