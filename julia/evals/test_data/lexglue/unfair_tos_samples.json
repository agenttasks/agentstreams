    ],
    "split": "test",
    "metadata": {},
    "labels": [],
    "label": null,
    "content_hash": "acedfd7170de6687fea962ef30a4e6a3"
  },
  {
    "task": "unfair_tos",
    "hf_index": 26,
    "text": "the specific information that we extract may depend on the privacy settings you have with the sns . \n",
    "label_set": [
