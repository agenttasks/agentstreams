    "labels": [],
    "label": null,
    "content_hash": "f09a64dd20cfdf1065cef56ce438a561"
  },
  {
    "task": "unfair_tos",
    "hf_index": 30,
    "text": "academia.edu reserves the right to suspend or terminate your account if any information provided during the registration process or thereafter proves to be inaccurate , not current or incomplete . \n",
    "label_set": [
      "limitation_of_liability",
      "unilateral_termination",
      "unilateral_change",
      "content_removal",
      "jurisdiction",
      "choice_of_law",
