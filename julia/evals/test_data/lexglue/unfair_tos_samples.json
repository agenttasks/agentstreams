    "content_hash": "a7d3a553ce16ad1d8bf71c15d79743c9"
  },
  {
    "task": "unfair_tos",
    "hf_index": 28,
    "text": "during the registration process , you will be required to provide certain information and you will establish a username and a password . \n",
    "label_set": [
      "limitation_of_liability",
      "unilateral_termination",
      "unilateral_change",
      "content_removal",
      "jurisdiction",
      "choice_of_law",
      "arbitration",
