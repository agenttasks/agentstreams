  },
  {
    "task": "unfair_tos",
    "hf_index": 34,
    "text": "see academia.edu 's privacy policy at academia.edu/privacy for information and notices concerning academia.edu 's collection and use of your personal information . \n",
    "label_set": [
      "limitation_of_liability",
      "unilateral_termination",
      "unilateral_change",
      "content_removal",
      "jurisdiction",
      "choice_of_law",
