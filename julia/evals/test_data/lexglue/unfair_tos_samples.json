    "labels": [],
    "label": null,
    "content_hash": "2418f41f348559ad1bdc9e8898fad00e"
  },
  {
    "task": "unfair_tos",
    "hf_index": 27,
    "text": "you hereby consent to our access to and collection of such personal information about you . \n",
    "label_set": [
      "limitation_of_liability",
      "unilateral_termination",
      "unilateral_change",
      "content_removal",
      "jurisdiction",
      "choice_of_law",
